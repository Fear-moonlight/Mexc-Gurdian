# Core
TIMEZONE=Asia/Kuala_Lumpur
LOG_LEVEL=INFO

# Monitoring rule
PERCENT_THRESHOLD=10
WINDOW_HOURS=4
POLL_SECONDS=60
REPEAT_ALERT_MINUTES=10
REQUIRE_MANUAL_ACK=true
RETRIGGER_AFTER_ACK=true

# Universe
EXCHANGE_ID=mexc
MARKET_TYPE=futures
QUOTE_CURRENCY=USDT
INCLUDE_ALL_USDT_PAIRS=true

# Telegram
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHAT_ID=replace_me
TELEGRAM_POLL_SECONDS=5

# Files
STATE_FILE=./data/state.json
COMMAND_FILE=./data/commands.jsonl
SQLITE_DB_PATH=./data/mexc_gurdian.db

# Web API / Dashboard
WEB_HOST=0.0.0.0
WEB_PORT=8080
